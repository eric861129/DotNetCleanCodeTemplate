{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=CleanCodeTemplate;User Id=sa;Password=Your_strong_password123;TrustServerCertificate=True"
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "Jwt": {
    "Issuer": "CleanCodeTemplate",
    "Audience": "CleanCodeTemplate",
    "SigningKey": "local-development-signing-key-please-change"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Observability": {
    "Enabled": false,
    "ServiceName": "CleanCodeTemplate.WebApi",
    "ServiceVersion": "1.0.0",
    "Tracing": {
      "Enabled": true
    },
    "Metrics": {
      "Enabled": true
    },
    "ConsoleExporter": {
      "Enabled": false
    },
    "OtlpExporter": {
      "Enabled": false,
      "Endpoint": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
